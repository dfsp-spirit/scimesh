CXX_STD = CXX17
CXX17FLAGS = -O2

PKG_CPPFLAGS = -I../src/core -I../src/third_party -I../src/third_party/glm -DSCIMESH_STB_WRITE_IMPL
PKG_CXXFLAGS =

OBJECTS = rcpp_bindings.o \
    RcppExports.o \
    core/image.o \
    core/camera.o \
    core/normals.o \
    core/clipping.o \
    core/rasterizer.o \
    core/renderer.o \
    core/primitives.o \
    core/transforms.o \
    core/obj_io.o \
    core/ply_io.o

all: $(SHLIB)
	-strip --strip-debug $(SHLIB)
